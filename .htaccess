<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Protect sensitive files at the web root
    RewriteRule ^(\.env|\.git|composer\.(json|lock)|artisan)$ - [F,L]

    # Block direct access to Laravel application internals under src/
    RewriteRule ^src/(vendor|storage|bootstrap|database|resources|tests)/ - [F,L]
    RewriteRule ^src/\.env - [F,L]

    # Redirect Trailing Slashes If Not A Folder
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Force HTTPS (Hostinger'da SSL aktifse)
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Serve images from Laravel public under src/
    # Örn: /images/service.png -> /src/public/images/service.png
    RewriteRule ^images/(.+)$ src/public/images/$1 [L]

    # Front controller
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>

# Basic security headers (best-effort, Hostinger mod_headers desteğine bağlı)
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "no-referrer-when-downgrade"

    # Görseller için uzun süreli browser cache
    <FilesMatch "\.(jpe?g|png|gif|webp)$">
        Header set Cache-Control "public, max-age=31536000"
    </FilesMatch>
</IfModule>
</IfModule>
